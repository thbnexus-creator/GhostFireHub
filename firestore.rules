rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives & Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ghostfirehub@gmail.com' ||
        request.auth.token.email == 'ghostfire@ghost.com'
      );
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email.toLowerCase() == email.toLowerCase();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\+\\.\\@]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 128 &&
             data.username is string && data.username.size() <= 50;
    }

    function isValidDevice(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.brand is string && data.brand.size() <= 64 &&
             data.model is string && data.model.size() <= 64;
    }

    function isValidWeapon(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 64 &&
             data.category is string && data.category.size() <= 64;
    }

    function isValidMarketplaceProduct(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 128 &&
             data.price is number;
    }

    function isValidCommunityPost(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 128 &&
             data.content is string && data.content.size() <= 5000;
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 128 &&
             data.message is string && data.message.size() <= 1024;
    }

    // --- Collections ---

    // 1. Users
    match /users/{email} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isOwner(email)) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // 2. Devices
    match /devices/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidDevice(incoming());
    }

    // 3. Weapons
    match /weapons/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidWeapon(incoming());
    }

    // 4. Marketplace Products
    match /marketplaceProducts/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidMarketplaceProduct(incoming());
    }

    // 5. Community Posts
    match /communityPosts/{id} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCommunityPost(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().author == request.auth.token.email)) && isValidCommunityPost(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().author == request.auth.token.email);
    }

    // 6. HUD Layouts
    match /hudLayouts/{email} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || isOwner(email));
    }

    // 7. Admin Activity Logs
    match /adminActivityLogs/{id} {
      allow read, write: if isAdmin();
    }

    // 8. Notifications
    match /notifications/{id} {
      allow read: if isSignedIn() && (existing().targetEmail == null || existing().targetEmail.toLowerCase() == request.auth.token.email.toLowerCase());
      allow write: if isAdmin() && isValidNotification(incoming());
    }
  }
}
