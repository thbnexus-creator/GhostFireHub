rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives & Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ghostfirehub@gmail.com' ||
        request.auth.token.email == 'ghostfire@ghost.com'
      );
    }

    // --- Collections ---

    // 1. Settings (Global configuration, global theme, ads, marketplace rules)
    match /settings/{doc} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 2. Users (Authenticated profile management)
    match /users/{uid} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // 3. Devices
    match /devices/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Weapons
    match /weapons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Marketplace Products
    match /marketplace/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (
        isSignedIn() && resource.data.vendorEmail == request.auth.token.email
      );
    }

    // 6. Community Posts
    match /communityPosts/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorEmail == request.auth.token.email);
    }

    // 7. HUD Layouts
    match /hudLayouts/{cleanedEmail} {
      allow read, write: if isSignedIn();
    }

    // 8. Admin Activity Logs
    match /adminActivityLogs/{id} {
      allow read, write: if isAdmin();
    }

    // 9. Notifications
    match /notifications/{id} {
      allow read, write: if isSignedIn();
    }

    // 10. Presets
    match /presets/{id} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorEmail == request.auth.token.email);
    }

    // 11. Giveaways
    match /giveaways/{id} {
      allow read: if true;
      allow update: if isSignedIn();
      allow create, delete: if isAdmin();
    }

    // 12. Vendor Tokens
    match /vendorTokens/{token} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow create, delete: if isAdmin();
    }

    // 13. Vendor Applications
    match /vendorApplications/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 14. Support Feedback / Issues
    match /feedback/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
